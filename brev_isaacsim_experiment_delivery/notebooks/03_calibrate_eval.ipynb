   "source": [
    "# 03 – Calibrate and Evaluate\n",
    "\n",
    "This notebook shows how to fit a temperature scaling model on held‑out validation episodes and run the policy with uncertainty‑calibrated safety gating.  We use dummy data for illustration because the real simulation is not available in this environment.  Replace the placeholders with actual evaluation loops when running on Brev."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "from src.utils.config import load_config\n",
    "from src.policy import OpenVLA, Octo\n",
    "from src.supervisor import TemperatureCalibrator, RiskEstimator, SafetyGatingStateMachine, ReobserveStrategy\n",
    "from src.logger import EpisodeLogger, StepLogger, InterventionLogger, ContactLogger\n",
    "import numpy as np\n",
    "\n",
    "# Load pilot configuration\n",
    "cfg = load_config('configs/pilot_config.yaml')\n",
    "\n",
    "# Fit temperature calibrator on dummy validation data\n",
    "calibrator = TemperatureCalibrator()\n",
    "# Generate fake logits and outcomes\n",
    "val_logits = np.random.normal(loc=0.0, scale=1.0, size=100)\n",
    "val_outcomes = np.random.binomial(n=1, p=0.7, size=100)\n",
    "tau = calibrator.fit(val_logits, val_outcomes)\n",
    "print(f'Fitted temperature τ={tau:.3f}')\n",
    "\n",
    "# Risk estimator and state machine\n",
    "risk_estimator = RiskEstimator(alpha=cfg['gating']['alpha'], beta=cfg['gating']['beta'])\n",
    "sm = SafetyGatingStateMachine(delta_low=cfg['gating']['delta_low'], delta_high=cfg['gating']['delta_high'])\n",
    "\n",
    "# Prepare loggers\n",
    "data_dir = Path('data_logs')\n",
    "data_dir.mkdir(exist_ok=True)\n",
    "episode_logger = EpisodeLogger(output_dir=data_dir)\n",
    "step_logger = StepLogger(output_dir=data_dir)\n",
    "intervention_logger = InterventionLogger(output_dir=data_dir)\n",
    "contact_logger = ContactLogger(output_dir=data_dir)\n",
    "\n",
    "# Dummy evaluation loop: iterate over a few episodes and simulate metrics\n",
    "for episode_idx in range(3):\n",
    "    run_id = 'pilot'\n",
    "    episode_id = f'{run_id}_ep{episode_idx}'\n",
    "    # Randomly choose task and method\n",
    "    task = np.random.choice(['drawer', 'clutter_sort'])\n",
    "    method = np.random.choice(['baseline', 'calibrated'])\n",
    "    policy_name = 'openvla'\n",
    "    # Create dummy policy\n",
    "    policy_cfg = cfg['policies'][policy_name]\n",
    "    policy = OpenVLA(policy_cfg)\n",
    "    policy.load_model()\n",
    "    policy.reset(instruction='pick up the object and place it')\n",
    "    # Simulate a few steps\n",
    "    success = False\n",
    "    for t in range(10):\n",
    "        obs = {'rgb': np.zeros((480,640,3), dtype=np.uint8), 'depth': np.zeros((480,640), dtype=np.float32), 'state': np.zeros(7)}\n",
        action, info = policy.act(obs)\n",
        # Calibrate confidence (use dummy logit = raw_confidence converted to logit)\n",
        logit = np.log(info['raw_policy_confidence'] + 1e-6) - np.log(1 - info['raw_policy_confidence'] + 1e-6)\n",
        calibrated_prob = calibrator.transform([logit])[0]\n+        risk = risk_estimator.estimate(calibrated_prob, info)\n+        state, event = sm.update(risk)\n+        # Log step
        step_logger.log_step({
            'episode_id': episode_id,
            't_step': t,
            'phase': 'dummy_phase',
            'ee_pose': '0,0,0',
            'joint_positions': '0,0,0,0,0,0,0',
            'raw_policy_confidence': info['raw_policy_confidence'],
            'raw_uncertainty': info['uncertainty_variance'],
            'uncertainty_entropy': info['uncertainty_entropy'],
            'uncertainty_variance': info['uncertainty_variance'],
            'calibrated_success_prob': calibrated_prob,
            'calibrated_failure_risk': risk,
            'gating_state': state.name.lower(),
            'action_vector': ','.join(map(str, action)),
            'observation_frame_path': ''
        })
        # Simulate interventions logging
        if event in ('pause', 'fallback'):
            intervention_logger.log_intervention({
                'episode_id': episode_id,
                't_step': t,
                'event_type': event,
                'phase': 'dummy_phase',
                'risk_before': risk,
                'risk_after': max(0.0, risk - 0.1),
                'world_x': 0.0,
                'world_y': 0.0,
                'world_z': 0.0,
                'resolved_by': 'pause_reobserve' if event == 'pause' else 'fallback_planner',
                'resume_success': True
            })
        # Dummy success condition: succeed at t=9
        if t == 9:
            success = True
    # Log episode summary
    episode_logger.log_episode({
        'run_id': run_id,
        'task': task,
        'method': method,
        'policy': policy_name,
        'seed': 0,
        'shift_axis': 'nominal',
        'shift_severity': 0,
        'instruction': 'pick up the object and place it',
        'success': success,
        'failure_reason': '' if success else 'dummy_failure',
        'collision_any': False,
        'collision_count': 0,
        'peak_contact_force_n': 0.0,
        'peak_contact_torque_nm': 0.0,
        'num_interventions': 0,
        'num_pause_reobserve': 0,
        'num_fallbacks': 0,
        'episode_wall_time_s': 0.0,
        'sim_time_s': 0.0,
        'object_in_bin': False,
        'drawer_closed': False,
        'timed_out': False,
        'video_path': ''
    })
\n",
    "print('Dummy evaluation complete.  Logs written to data_logs/')"
   ]
  }
 ],
